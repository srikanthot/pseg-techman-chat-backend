# ─────────────────────────────────────────────────────────────────────────────
# PSEG Tech Manual Agent Backend — Environment Variable Template
#
# Copy this file to .env and fill in your values.
# No API keys required — all authentication uses Managed Identity.
#
# Local development:  sign in with `az login` before starting the server.
# Azure App Service:  assign the RBAC roles listed in README.md to the
#                     system-assigned managed identity.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
# Agent Framework SDK also reads AZURE_OPENAI_CHAT_DEPLOYMENT_NAME — keep in sync
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-ada-002

# Managed Identity token scope — override for Azure Government (GCC High):
# AZURE_OPENAI_TOKEN_SCOPE=https://cognitiveservices.azure.us/.default
AZURE_OPENAI_TOKEN_SCOPE=https://cognitiveservices.azure.com/.default

# ── Azure AI Search ───────────────────────────────────────────────────────────
# No API key — DefaultAzureCredential is used directly by SearchClient.
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_INDEX=rag-psegtechm-index-finalv2

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (never a wildcard).
# Default when this variable is NOT set: http://localhost:3000,http://localhost:8000
#
# Production (Power Apps / PCF) — override with your actual domains:
#   ALLOWED_ORIGINS=https://apps.powerapps.com,https://your-org.crm.dynamics.com
#
# IMPORTANT: Always override in production. Never leave localhost origins in prod.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Index field mappings ──────────────────────────────────────────────────────
# These MUST match the field names in your Azure AI Search index schema exactly.
SEARCH_CONTENT_FIELD=chunk
SEARCH_SEMANTIC_CONTENT_FIELD=chunk_for_semantic
SEARCH_VECTOR_FIELD=text_vector
SEARCH_FILENAME_FIELD=source_file
SEARCH_URL_FIELD=source_url
SEARCH_CHUNK_ID_FIELD=chunk_id
SEARCH_TITLE_FIELD=title
SEARCH_SECTION1_FIELD=header_1
SEARCH_SECTION2_FIELD=header_2
SEARCH_SECTION3_FIELD=header_3
# Leave blank if your index has no page number field:
SEARCH_PAGE_FIELD=

# ── Retrieval tuning ──────────────────────────────────────────────────────────
TOP_K=5
RETRIEVAL_CANDIDATES=15
VECTOR_K=50

# ── Confidence gate ───────────────────────────────────────────────────────────
USE_SEMANTIC_RERANKER=true
SEMANTIC_CONFIG_NAME=manual-semantic-config
QUERY_LANGUAGE=en-us

# Score-first gate: a chunk passing the score threshold passes regardless of count.
# MIN_RESULTS is consulted only when the top score also fails.
MIN_RESULTS=1

# Gate threshold applied to the TOP chunk's score (not the average):
#   With semantic reranker: reranker_score range 0.0 – 4.0
#   Without reranker:       RRF / hybrid score range 0.01 – 0.033
MIN_AVG_SCORE=0.01
MIN_RERANKER_SCORE=0.2

# ── Diversity filtering ───────────────────────────────────────────────────────
DIVERSITY_BY_SOURCE=true
MAX_CHUNKS_PER_SOURCE=2
DOMINANT_SOURCE_SCORE_RATIO=1.5
MAX_CHUNKS_DOMINANT_SOURCE=4
SCORE_GAP_MIN_RATIO=0.55

# ── Session / conversation history ────────────────────────────────────────────
# false (default) — stateless: every request is independent (Agent Framework
#   creates a fresh AFAgentSession per request; InMemoryHistoryProvider not used).
#   Safe for App Service scale-out and restarts.
#
# true — Agent Framework InMemoryHistoryProvider accumulates multi-turn history
#   in AFAgentSession.state per session_id.  Single-process only (local dev/demos).
#   History is lost on restart or scale-out.
ENABLE_IN_MEMORY_HISTORY=false

# ── Debug ─────────────────────────────────────────────────────────────────────
# true — log detailed retrieval trace: scores, sections, content previews,
#         diversity filter decisions, and injected context blocks.
TRACE_MODE=false
