# ─────────────────────────────────────────────────────────────────────────────
# PSEG Tech Manual Chat Backend — Environment Variable Template
#
# Copy this file to .env and fill in your values.
# No secrets are required — authentication uses Managed Identity.
#
# Local development:  sign in with `az login` before starting the server.
# Azure App Service:  assign the roles listed in README.md to the managed identity.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-ada-002

# Azure AD token scope — override for Azure Government (GCC High):
# AZURE_OPENAI_TOKEN_SCOPE=https://cognitiveservices.azure.us/.default

# ── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_INDEX=rag-psegtechm-index-finalv2

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
#
# Leave blank (default) → wildcard mode: allow_origins=["*"], credentials=False.
# This is safe for Power Apps / PCF integrations that send bearer tokens
# in Authorization headers rather than cookies.
#
# Set to specific origins to enable credential-bearing (cookie) requests:
# ALLOWED_ORIGINS=https://apps.powerapps.com,https://your-org.dynamics.com
ALLOWED_ORIGINS=

# ── Index field mappings ──────────────────────────────────────────────────────
# These MUST match the field names in your Azure AI Search index schema exactly.
SEARCH_CONTENT_FIELD=chunk
SEARCH_SEMANTIC_CONTENT_FIELD=chunk_for_semantic
SEARCH_VECTOR_FIELD=text_vector
SEARCH_FILENAME_FIELD=source_file
SEARCH_URL_FIELD=source_url
SEARCH_CHUNK_ID_FIELD=chunk_id
SEARCH_TITLE_FIELD=title
SEARCH_SECTION1_FIELD=header_1
SEARCH_SECTION2_FIELD=header_2
SEARCH_SECTION3_FIELD=header_3
# Leave blank if your index has no page number field:
SEARCH_PAGE_FIELD=

# ── Retrieval tuning ──────────────────────────────────────────────────────────
TOP_K=5
RETRIEVAL_CANDIDATES=15
VECTOR_K=50

# ── Quality / confidence gate ─────────────────────────────────────────────────
USE_SEMANTIC_RERANKER=true
SEMANTIC_CONFIG_NAME=manual-semantic-config
QUERY_LANGUAGE=en-us

# Minimum number of retrieved chunks required to attempt generation.
# Default is 1 — a single highly relevant chunk is sufficient.
MIN_RESULTS=1

# Gate thresholds applied to the TOP chunk's score (not the average).
# With semantic reranker:  reranker_score range 0.0 – 4.0
# Without reranker:        RRF / hybrid score range 0.01 – 0.033
MIN_AVG_SCORE=0.01
MIN_RERANKER_SCORE=0.2

# ── Diversity filtering ───────────────────────────────────────────────────────
DIVERSITY_BY_SOURCE=true
MAX_CHUNKS_PER_SOURCE=2
DOMINANT_SOURCE_SCORE_RATIO=1.5
MAX_CHUNKS_DOMINANT_SOURCE=4
SCORE_GAP_MIN_RATIO=0.55

# ── Session / conversation history ────────────────────────────────────────────
# Disabled by default — the backend is stateless, which is safe for App Service
# scale-out and restarts.
# Set to true only for single-instance local development or demos where
# losing history on restart is acceptable.
ENABLE_IN_MEMORY_HISTORY=false

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to true to log detailed retrieval trace information (scores, sections, previews)
TRACE_MODE=false
